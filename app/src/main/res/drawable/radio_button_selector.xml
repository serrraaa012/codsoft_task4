<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Checked/Selected state -->
    <item android:state_checked="true">
        <shape>
            <solid android:color="#6C63FF"/>
            <corners android:radius="12dp"/>
            <stroke android:width="2dp" android:color="#4A3FB5"/>
            <padding android:left="16dp" android:top="12dp" android:right="16dp" android:bottom="12dp"/>
        </shape>
    </item>

    <!-- Pressed state -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#D0CCFF"/>
            <corners android:radius="12dp"/>
            <stroke android:width="2dp" android:color="#6C63FF"/>
            <padding android:left="16dp" android:top="12dp" android:right="16dp" android:bottom="12dp"/>
        </shape>
    </item>

    <!-- Default state -->
    <item>
        <shape>
            <solid android:color="#F0F0F5"/>
            <corners android:radius="12dp"/>
            <stroke android:width="1.5dp" android:color="#6C63FF"/>
            <padding android:left="16dp" android:top="12dp" android:right="16dp" android:bottom="12dp"/>
        </shape>
    </item>
</selector>